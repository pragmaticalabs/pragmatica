# ============================================================
# Whitespace (auto-skipped, includes comments)
# ============================================================
%whitespace <- ([ \t\r\n]+ / LineComment / BlockComment)*
LineComment <- '--' [^\n]*
BlockComment <- '/*' (!'*/' .)* '*/'
